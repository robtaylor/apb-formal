// IHI0024E Figure 3-1 — Write transfer with no wait states.
// Phases: T0 IDLE, T1 SETUP (PSEL=1,PENABLE=0), T2 ACCESS (PENABLE=1,PREADY=1 -> data
// accepted at T3), T3 return to IDLE. Tick number n == spec cycle Tn.
{
  signal: [
    { name: 'PCLK',    wave: 'p....' },
    { name: 'PADDR',   wave: 'x=.x.', data: ['Addr 1'] },
    { name: 'PWRITE',  wave: '01.0.' },
    { name: 'PSEL',    wave: '01.0.' },
    { name: 'PENABLE', wave: '0.10.' },
    { name: 'PWDATA',  wave: 'x=.x.', data: ['Data 1'] },
    { name: 'PREADY',  wave: '0.10.' },
  ],
  head: { text: 'Figure 3-1  Write transfer with no wait states', tick: 0 },
}
