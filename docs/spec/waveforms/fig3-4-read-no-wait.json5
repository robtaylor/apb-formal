// IHI0024E Figure 3-4 — Read transfer with no wait states.
// PWRITE LOW (read). T1 SETUP; T2 ACCESS (PENABLE=1, PREADY=1). Completer drives PRDATA
// during the ACCESS cycle; Requester captures it at T3. Tick n == spec cycle Tn.
{
  signal: [
    { name: 'PCLK',    wave: 'p....' },
    { name: 'PADDR',   wave: 'x=.x.', data: ['Addr 1'] },
    { name: 'PWRITE',  wave: '0....' },
    { name: 'PSEL',    wave: '01.0.' },
    { name: 'PENABLE', wave: '0.10.' },
    { name: 'PRDATA',  wave: 'x.=x.', data: ['Data 1'] },
    { name: 'PREADY',  wave: '0.10.' },
  ],
  head: { text: 'Figure 3-4  Read transfer with no wait states', tick: 0 },
}
